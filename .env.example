# Amazon Scraper Configuration
AMAZON_BASE_URL=https://www.amazon.com
CHROME_DRIVER_PATH=/path/to/chromedriver
HEADLESS_MODE=True

# Output Settings
OUTPUT_FORMAT=csv  # csv or json
OUTPUT_DIR=data

# Scraping Settings
MAX_PAGES=10
SCROLL_PAUSE_TIME=2
REQUEST_TIMEOUT=30

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/scraper.log 